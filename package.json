    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "nodemailer": "^8.0.6"
  }
}
