{
  "name": "live-music-scout",
  "version": "0.1.0",
  "private": true,
  "description": "Local TypeScript CLI for scouting Seattle-area live music tonight.",
  "scripts": {
    "scout": "node --import tsx src/index.ts",
    "scout:email": "node --import tsx src/scoutEmail.ts",
